<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # React SPA — serve index.html for all non-file routes so React Router works
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
    # Cache JS/CSS assets for 1 week (they have content hashes in filenames)
    <If "%{REQUEST_URI} =~ m#^/assets/.*$#">
        Header set Cache-Control "public, max-age=604800"
    </If>
    # Never cache index.html so users always get the latest version
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# Enable Gzip compression for faster page loads
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

